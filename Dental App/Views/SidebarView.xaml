        <!-- Section Title Style -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="20,20,0,12"/>
        </Style>

        <!-- Navigation Button Style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="12,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="12" Background="Transparent" Padding="16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path x:Name="icon" 
                                      Data="{TemplateBinding Tag}" 
                                      Fill="{TemplateBinding Foreground}" 
                                      Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Content}" 
                                           VerticalAlignment="Center" 
                                           Margin="16,0,0,0" 
                                           FontSize="14" FontWeight="Medium" Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SecondaryBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active Button Style -->
        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="12" Background="{DynamicResource AccentColor}" Padding="16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path x:Name="icon" 
                                      Data="{TemplateBinding Tag}" 
                                      Fill="{DynamicResource TextPrimary}" 
                                      Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Content}" 
                                           VerticalAlignment="Center" 
                                           Margin="16,0,0,0" 
                                           FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo Section -->
        <Border Background="{DynamicResource PrimaryBackground}" Padding="20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="40" Height="40" Background="{DynamicResource AccentColor}" CornerRadius="10">
                    <Path Data="{StaticResource IconLogo}" Fill="White" Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <TextBlock Text="DentaCare Pro" Foreground="{DynamicResource AccentColor}" FontSize="18" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Navigation Sections -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <!-- PRINCIPAL Section -->
                <TextBlock Text="PRINCIPAL" Style="{StaticResource SectionTitleStyle}"/>
                
                <Button Content="Dashboard" Tag="{StaticResource IconDashboard}" 
                        x:Name="DashboardButton"
                        Command="{Binding NavigateCommand}" CommandParameter="DashboardView"/>
                
                <Button Content="Rendez-Vous" Tag="{StaticResource IconCalendar}" 
                        x:Name="RendezVousButton"
                        Command="{Binding NavigateCommand}" CommandParameter="RendezVousView"/>
                
                <Button Content="Consultation" Tag="{StaticResource IconConsultation}" 
                        x:Name="ConsultationButton"
                        Command="{Binding NavigateCommand}" CommandParameter="ConsultationView"/>

                <!-- PATIENTS Section -->
                <TextBlock Text="PATIENTS" Style="{StaticResource SectionTitleStyle}"/>
                
                <Button Content="Patients" Tag="{StaticResource IconPatients}" 
                        x:Name="PatientsButton"
                        Command="{Binding NavigateCommand}" CommandParameter="PatientsView"/>
                
                <Button Content="Antecedents" Tag="{StaticResource IconAntecedents}" 
                        x:Name="AntecedentsButton"
                        Command="{Binding NavigateCommand}" CommandParameter="AntecedentsView"/>
                
                <Button Content="Ordonnances" Tag="{StaticResource IconOrdonnances}" 
                        x:Name="OrdonnancesButton"
                        Command="{Binding NavigateCommand}" CommandParameter="OrdonnanceView"/>
                
                <Button Content="Actes Medicaux" Tag="{StaticResource IconActes}" 
                        x:Name="ActesMedicauxButton"
                        Command="{Binding NavigateCommand}" CommandParameter="ActesMedicauxView"/>
                
                <Button Content="Radio Images" Tag="{StaticResource IconRadio}" 
                        x:Name="RadioImagesButton"
                        Command="{Binding NavigateCommand}" CommandParameter="RadioImagesView"/>
                
                <Button Content="Odontogramme" Tag="{StaticResource IconOdonto}" 
                        x:Name="OdontogrammeButton"
                        Command="{Binding NavigateCommand}" CommandParameter="OdontogrammeView"/>

                <!-- FINANCES Section -->
                <TextBlock Text="FINANCES" Style="{StaticResource SectionTitleStyle}"/>
                
                <Button Content="Caisse" Tag="{StaticResource IconCaisse}" 
                        x:Name="CaisseButton"
                        Command="{Binding NavigateCommand}" CommandParameter="CaisseView"/>

                <!-- PROTHESE Section -->
                <TextBlock Text="PROTHESE" Style="{StaticResource SectionTitleStyle}"/>
                
                <Button Content="Commande Protesiste" Tag="{StaticResource IconProthese}" 
                        x:Name="CommandeProthesisteButton"
                        Command="{Binding NavigateCommand}" CommandParameter="CommandeProthesisteView"/>
                
                <Button Content="Protesistes" Tag="{StaticResource IconProthesistes}" 
                        x:Name="ProthesistesButton"
                        Command="{Binding NavigateCommand}" CommandParameter="ProthesistesView"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
