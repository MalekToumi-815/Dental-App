<UserControl x:Class="Dental_App.Views.OrdonnanceTemplateDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="b2v"/>
        
        <!-- Add standard inverse boolean to visibility converter -->
        <Style x:Key="InverseVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasImage}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Thumbs for Resizing the box corners -->
        <Style x:Key="ResizeThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Background" Value="#0F766E"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="{TemplateBinding BorderThickness}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalElementBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0F766E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource DialogBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Parametres du modele d'ordonnance" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource TextPrimary}"/>
                    <!-- Add a Close button here -->
                    <Button Grid.Column="1" Command="{Binding CancelCommand}" Style="{StaticResource CancelButtonStyle}" Content="✕" FontSize="18" Padding="10,5" Margin="0,-10,-10,0"/>
                </Grid>
                <TextBlock Text="Importez une image de fond et definissez la zone de depart du texte (X/Y)." Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <Button Content="Importer une Image" Style="{StaticResource ActionButtonStyle}" Command="{Binding ImportImageCommand}"/>
                    <!-- Move Enregistrer button here -->
                    <Button Content="Enregistrer" Command="{Binding SaveCommand}" Style="{StaticResource SaveButtonStyle}" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Canvas Area (Visible only if image exists) -->
            <Border Grid.Row="1" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Background="{DynamicResource PrimaryBackground}" Visibility="{Binding HasImage, Converter={StaticResource b2v}}">
                
                <!-- ViewBox handles the scaling perfectly. No matter how large the actual image, it scales down visually to fit the screen.
                     But the Canvas inside retains the ACTUAL pixel dimensions, meaning your X/Y coordinates remain 100% accurate for printing! -->
                <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5">
                    
                    <Canvas x:Name="OverlayCanvas" 
                            Width="{Binding ImageWidth}" 
                            Height="{Binding ImageHeight}"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                            MouseMove="Canvas_MouseMove"
                            MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                            Background="Transparent">

                        <Image x:Name="BackgroundImage" Source="{Binding ImageSource}" Stretch="None" Canvas.Left="0" Canvas.Top="0"/>

                        <!-- The draggable box Wrapper -->
                        <Grid x:Name="DraggableBox" 
                              Width="{Binding BoxWidth, Mode=TwoWay}" 
                              Height="{Binding BoxHeight, Mode=TwoWay}" 
                              Canvas.Left="{Binding X, Mode=TwoWay}" 
                              Canvas.Top="{Binding Y, Mode=TwoWay}">
                            
                            <!-- Semi-transparent overlay body (the "zone") -->
                            <Border Background="#200F766E" 
                                    BorderBrush="#0F766E" 
                                    BorderThickness="2"
                                    CornerRadius="4" 
                                    IsHitTestVisible="False">
                                <TextBlock Text="Zone de texte (Dép. XY)" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           Foreground="#0F766E" FontWeight="Bold"/>
                            </Border>

                            <!-- The Resize Thumbs (Corners) -->
                            <Thumb Style="{StaticResource ResizeThumbStyle}" 
                                   HorizontalAlignment="Left" VerticalAlignment="Top" 
                                   Margin="-5,-5,0,0" Cursor="SizeNWSE" 
                                   DragDelta="Thumb_DragDelta_TopLeft"/>
                            
                            <Thumb Style="{StaticResource ResizeThumbStyle}" 
                                   HorizontalAlignment="Right" VerticalAlignment="Top" 
                                   Margin="0,-5,-5,0" Cursor="SizeNESW" 
                                   DragDelta="Thumb_DragDelta_TopRight"/>
                            
                            <Thumb Style="{StaticResource ResizeThumbStyle}" 
                                   HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                                   Margin="-5,0,0,-5" Cursor="SizeNESW" 
                                   DragDelta="Thumb_DragDelta_BottomLeft"/>
                            
                            <Thumb Style="{StaticResource ResizeThumbStyle}" 
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                                   Margin="0,0,-5,-5" Cursor="SizeNWSE" 
                                   DragDelta="Thumb_DragDelta_BottomRight"/>
                            

                        </Grid>
                    </Canvas>
                </Viewbox>
            </Border>

            <!-- No Image Placeholder -->
            <Border Grid.Row="1" Background="{DynamicResource PrimaryBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                    Style="{StaticResource InverseVisibilityStyle}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Aucune image importee" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Veuillez importer une image d'en-tete pour configurer la zone de texte." Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
