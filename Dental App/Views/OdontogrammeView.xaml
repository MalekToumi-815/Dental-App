<UserControl x:Class="Dental_App.Views.OdontogrammeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:ink="clr-namespace:System.Windows.Ink;assembly=PresentationCore"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource PrimaryBackground}">

    <UserControl.Resources>
        <!-- Toolbar Toggle Button Style -->
        <Style x:Key="ToolbarToggleButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" CornerRadius="6" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryBackground}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OdontogrammeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OdontogrammeSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SecondaryBackground}"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <!-- Background -->
                            <Border x:Name="bg" CornerRadius="25" Background="{TemplateBinding Background}" BorderThickness="0"/>
                            
                            <!-- Left label container -->
                            <StackPanel x:Name="leftContainer" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Width="55">
                                <TextBlock Text="[H]" FontSize="12" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" Width="55" TextAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            
                            <!-- Right label container -->
                            <StackPanel x:Name="rightContainer" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Right" Width="55">
                                <TextBlock Text="[E]" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="55" TextAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            
                            <!-- Animated circle -->
                            <Border x:Name="thumb" CornerRadius="20" Background="White" Width="40" Height="40" 
                                    HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Center">
                            </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Data Trigger Animation Helper -->
        <Style x:Key="ToggleSwitchAnimatedStyle" TargetType="Button" BasedOn="{StaticResource ToggleSwitchStyle}">
        </Style>

        <!-- Tooth Logo Geometry -->
        <Geometry x:Key="IconLogo">
            M12,2C10,2 9.5,3.5 8,4.5C6,5.5 4,6 4,11C4,15 5.5,20 7.5,21C9.5,22 11,21 12,20C13,21 14.5,22 16.5,21C18.5,20 20,15 20,11C20,6 18,5.5 16,4.5C14.5,3.5 14,2 12,2Z
        </Geometry>

        <!-- History/Clock Icon -->
        <Geometry x:Key="IconHistory">
            M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2M12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4M12.5,6H11V13L17.2,16.2L18.0,15.1L12.5,12.2V6Z
        </Geometry>

        <!-- Pen/Edit Icon -->
        <Geometry x:Key="IconPen">
            M3,17.25V21h3.75L17.81,9.94l-3.75,-3.75L3,17.25Z M20.71,7.04c0.39,-0.39 0.39,-1.02 0,-1.41l-2.34,-2.34c-0.39,-0.39 -1.02,-0.39 -1.41,0l-1.83,1.83 3.75,3.75 1.83,-1.83Z
        </Geometry>

        <!-- Eraser Icon -->
        <Geometry x:Key="IconEraser">
            M2.5 17.5L5.4 20.4H22V18.4H17.3L21.4 14.3C22 13.5 22 12.3 21.4 11.5L16.6 6.6C16.2 6.2 15.6 6 15.1 6C14.6 6 14.1 6.2 13.7 6.6L2.5 17.5Zm12.6-9.6L20 12.7L17.5 15.2L12.6 10.4L15.1 7.9ZM11.2 11.8L16 16.7L10.2 22.4H5.4L4 21L11.2 11.8Z
        </Geometry>

        <!-- Thumb Animation Style -->
        <Style x:Key="ThumbAnimationStyle" TargetType="Ellipse">
            <Setter Property="Margin" Value="0,0,25,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHistoryMode}" Value="False">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    To="0,0,75,0" Duration="0:0:0.3">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    To="0,0,25,0" Duration="0:0:0.3">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- DataTemplate for Acts History Items -->
        <DataTemplate x:Key="ActsHistoryTemplate">
            <Border Background="{DynamicResource SecondaryBackground}" 
                    CornerRadius="8" 
                    Padding="16" 
                    Margin="0,0,0,12"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderColor}">
                <StackPanel>
                    <!-- Consultation Date Header -->
                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderColor}" Padding="0,0,0,12" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="[Date]" FontSize="14" Margin="0,0,8,0" Foreground="{DynamicResource AccentColor}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding DateFormatted}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Acts List -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Actes realises:" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,0,0,8"
                                   Opacity="0.8"/>
                        <ItemsControl ItemsSource="{Binding Actes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackground}" 
                                            CornerRadius="4" 
                                            Padding="8,6"
                                            Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="[+]" 
                                                       FontSize="11" 
                                                       Foreground="{DynamicResource AccentColor}"
                                                       Margin="0,0,8,0"
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding}" 
                                                       FontSize="12" 
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Notes -->
                    <Border Background="{DynamicResource CardBackground}" 
                            CornerRadius="6" 
                            Padding="12" 
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderColor}">
                        <StackPanel>
                            <TextBlock Text="Notes:" 
                                       FontSize="11" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,6"
                                       Opacity="0.8"/>
                            <TextBlock Text="{Binding Notes}" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextWrapping="Wrap"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title and Patient Info -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Odontogramme" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="{Binding PatientInfo}" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Toggle Switch -->
                <Border Width="130" Height="50" CornerRadius="25" Background="{DynamicResource BorderColor}" 
                        Cursor="Hand" MouseDown="ToggleSwitch_MouseDown" Margin="0,0,16,0">
                    <Grid ClipToBounds="True">
                        <!-- Background -->
                        <Border x:Name="ToggleBg" CornerRadius="25" Background="{DynamicResource BorderColor}" />
                        
                        <!-- Icons Container (behind the thumb) -->
                        <Grid Panel.ZIndex="1">
                            <!-- Left section (History) -->
                            <Grid HorizontalAlignment="Left" Width="65" Margin="15,0,0,0" ClipToBounds="True">
                                <Path Data="{StaticResource IconHistory}" Fill="White" 
                                      Width="18" Height="18" 
                                      Stretch="Uniform"
                                      VerticalAlignment="Center" HorizontalAlignment="Left"
                                      Margin="8,0,0,0"/>
                            </Grid>
                            
                            <!-- Right section (Edit/Pen) -->
                            <Grid HorizontalAlignment="Right" Width="65" Margin="0,0,5,0" ClipToBounds="True">
                                <Path Data="{StaticResource IconPen}" Fill="{DynamicResource TextSecondary}" 
                                      Width="18" Height="18" 
                                      Stretch="Uniform"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                        </Grid>
                        
                        <!-- Animated circle thumb with higher Z-index -->
                        <Ellipse x:Name="ToggleThumb" Width="40" Height="40" Fill="White" 
                                 HorizontalAlignment="Right" 
                                 VerticalAlignment="Center"
                                 Panel.ZIndex="100"
                                 Style="{StaticResource ThumbAnimationStyle}"/>
                    </Grid>
                </Border>
                
                <!-- Patient Selection Button -->
                <Button Content="Choisir Patient" Style="{StaticResource OdontogrammeButtonStyle}" Command="{Binding ChoisirPatientCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Content Section -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Dental Schema Section -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="30" Margin="0,0,20,0">
                <!-- Dental Schema with Template Image -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Drawing Toolbar - Only visible in Edit Mode -->
                    <Border Grid.Row="0" 
                            Background="{DynamicResource SecondaryBackground}" 
                            Padding="10" 
                            CornerRadius="8" 
                            Margin="0,0,0,10" 
                            BorderBrush="{DynamicResource BorderColor}" 
                            BorderThickness="1"
                            Visibility="{Binding IsHistoryMode, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- Pen Mode Button -->
                            <RadioButton x:Name="PenBtn" 
                                         IsChecked="True" 
                                         Style="{StaticResource ToolbarToggleButtonStyle}" 
                                         Checked="SetPenMode" 
                                         Margin="0,0,10,0" 
                                         Padding="10,5">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconPen}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Stylo" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            
                            <!-- Eraser Mode Button -->
                            <RadioButton x:Name="EraserBtn" 
                                         Style="{StaticResource ToolbarToggleButtonStyle}" 
                                         Checked="SetEraserMode" 
                                         Margin="0,0,10,0" 
                                         Padding="10,5">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconEraser}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Gomme" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- Separator -->
                            <Separator Margin="10,0" Background="{DynamicResource BorderColor}"/>

                            <!-- Thickness Control -->
                            <TextBlock Text="Taille :" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,5,0"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <Slider x:Name="ThicknessSlider" 
                                    Width="100" 
                                    Minimum="1" 
                                    Maximum="20" 
                                    Value="2" 
                                    VerticalAlignment="Center" 
                                    ValueChanged="ThicknessSlider_ValueChanged"/>
                            <TextBlock x:Name="ThicknessValue" 
                                       Text="2" 
                                       VerticalAlignment="Center" 
                                       Margin="5,0,0,0"
                                       Foreground="{DynamicResource TextPrimary}"
                                       Width="20"/>

                            <!-- Separator -->
                            <Separator Margin="10,0" Background="{DynamicResource BorderColor}"/>

                            <!-- Color Control -->
                            <TextBlock Text="Couleur :" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,5,0"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <Button x:Name="ColorPickerButton"
                                    Content="Choisir" 
                                    Click="PickColor_Click" 
                                    Padding="10,5"
                                    Style="{StaticResource OdontogrammeSecondaryButtonStyle}"/>
                            <Rectangle x:Name="ColorPreview" 
                                       Width="20" 
                                       Height="20" 
                                       Fill="Red" 
                                       Margin="5,0" 
                                       Stroke="{DynamicResource BorderColor}"
                                       StrokeThickness="1"/>
                        </StackPanel>
                    </Border>

                    <!-- Dental Schema Container -->
                    <Grid Grid.Row="1">
                        <!-- Background Image -->
                        <Image x:Name="OdontogrammeImage"
                               Stretch="UniformToFill" 
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Width="645.0" Height="553.0"/>
                        
                        <!-- Tooth Paths Overlay loaded from XAML -->
                        <Grid x:Name="ToothOverlayGrid" Panel.ZIndex="10" MouseDown="ToothOverlay_MouseDown"/>

                        <!-- InkCanvas for Drawing - Only visible in Edit Mode (when IsHistoryMode = False) -->
                        <InkCanvas x:Name="FreeDrawCanvas"
                                   Panel.ZIndex="20"
                                   Background="Transparent"
                                   EditingMode="Ink"
                                   Visibility="{Binding IsHistoryMode, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                            <InkCanvas.DefaultDrawingAttributes>
                                <DrawingAttributes x:Name="CurrentAttributes" Color="Red" Width="2" Height="2"/>
                            </InkCanvas.DefaultDrawingAttributes>
                        </InkCanvas>
                    </Grid>
                </Grid>
            </Border>

            <!-- Right Panel - Historiques des Actes -->
            <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab Header -->
                    <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderColor}" Padding="0,0,0,16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Historiques des Actes" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding SelectedToothInfo}" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextSecondary}" 
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab Content -->
                    <Grid Grid.Row="1">
                        <!-- Initial Placeholder Message - Shown when no tooth selected -->
                        <StackPanel HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsNoActsMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   x:Name="NoToothSelectedPanel">
                            <Border HorizontalAlignment="Center" Width="60" Height="60" CornerRadius="30" Background="{DynamicResource AccentColor}">
                                <Path Data="{StaticResource IconLogo}" Fill="White" Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding NoToothSelectedMessage}" 
                                       Foreground="{DynamicResource TextSecondary}" 
                                       FontSize="14" 
                                       TextAlignment="Center"
                                       Margin="0,20,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Acts List - Shown when acts are loaded -->
                        <ScrollViewer Visibility="{Binding IsNoActsMessage, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ActsHistory}" 
                                         ItemTemplate="{StaticResource ActsHistoryTemplate}"
                                         Margin="0,0,8,0"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
