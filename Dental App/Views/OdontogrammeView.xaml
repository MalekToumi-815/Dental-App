<UserControl x:Class="Dental_App.Views.OdontogrammeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource PrimaryBackground}">

    <UserControl.Resources>
        <Style x:Key="OdontogrammeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OdontogrammeSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SecondaryBackground}"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tooth Logo Geometry -->
        <Geometry x:Key="IconLogo">
            M12,2C10,2 9.5,3.5 8,4.5C6,5.5 4,6 4,11C4,15 5.5,20 7.5,21C9.5,22 11,21 12,20C13,21 14.5,22 16.5,21C18.5,20 20,15 20,11C20,6 18,5.5 16,4.5C14.5,3.5 14,2 12,2Z
        </Geometry>

        <!-- DataTemplate for Acts History Items -->
        <DataTemplate x:Key="ActsHistoryTemplate">
            <Border Background="{DynamicResource SecondaryBackground}" 
                    CornerRadius="8" 
                    Padding="16" 
                    Margin="0,0,0,12"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderColor}">
                <StackPanel>
                    <!-- Consultation Date Header -->
                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderColor}" Padding="0,0,0,12" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="[Date]" FontSize="14" Margin="0,0,8,0" Foreground="{DynamicResource AccentColor}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding DateFormatted}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Acts List -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Actes realises:" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,0,0,8"
                                   Opacity="0.8"/>
                        <ItemsControl ItemsSource="{Binding Actes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackground}" 
                                            CornerRadius="4" 
                                            Padding="8,6"
                                            Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="[+]" 
                                                       FontSize="11" 
                                                       Foreground="{DynamicResource AccentColor}"
                                                       Margin="0,0,8,0"
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding}" 
                                                       FontSize="12" 
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Notes -->
                    <Border Background="{DynamicResource CardBackground}" 
                            CornerRadius="6" 
                            Padding="12" 
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderColor}">
                        <StackPanel>
                            <TextBlock Text="Notes:" 
                                       FontSize="11" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,6"
                                       Opacity="0.8"/>
                            <TextBlock Text="{Binding Notes}" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextWrapping="Wrap"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title and Patient Info -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Odontogramme" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="{Binding PatientInfo}" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Choisir Patient" Style="{StaticResource OdontogrammeButtonStyle}" Command="{Binding ChoisirPatientCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Content Section -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Dental Schema Section -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="30" Margin="0,0,20,0">
                <!-- Dental Schema with Template Image -->
                <Grid>
                    <!-- Background Image -->
                    <Image x:Name="OdontogrammeImage"
                           Stretch="UniformToFill" 
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Width="645.0" Height="553.0"/>
                    
                    <!-- Tooth Paths Overlay loaded from XAML -->
                    <Grid x:Name="ToothOverlayGrid" Panel.ZIndex="10" MouseDown="ToothOverlay_MouseDown"/>
                </Grid>
            </Border>

            <!-- Right Panel - Historiques des Actes -->
            <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab Header -->
                    <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderColor}" Padding="0,0,0,16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Historiques des Actes" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding SelectedToothInfo}" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextSecondary}" 
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab Content -->
                    <Grid Grid.Row="1">
                        <!-- Initial Placeholder Message - Shown when no tooth selected -->
                        <StackPanel HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsNoActsMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   x:Name="NoToothSelectedPanel">
                            <Border HorizontalAlignment="Center" Width="60" Height="60" CornerRadius="30" Background="{DynamicResource AccentColor}">
                                <Path Data="{StaticResource IconLogo}" Fill="White" Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding NoToothSelectedMessage}" 
                                       Foreground="{DynamicResource TextSecondary}" 
                                       FontSize="14" 
                                       TextAlignment="Center"
                                       Margin="0,20,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Acts List - Shown when acts are loaded -->
                        <ScrollViewer Visibility="{Binding IsNoActsMessage, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ActsHistory}" 
                                         ItemTemplate="{StaticResource ActsHistoryTemplate}"
                                         Margin="0,0,8,0"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
