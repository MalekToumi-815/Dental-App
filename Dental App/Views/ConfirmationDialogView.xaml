<UserControl x:Class="Dental_App.Views.ConfirmationDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource GlobalElementBorderBrush}" BorderThickness="1" MinWidth="360">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>

            <TextBlock Grid.Row="1" TextWrapping="Wrap" Text="{Binding Message}" Margin="0,12,0,0" Foreground="{DynamicResource TextSecondary}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2" Margin="0,18,0,0">
                <Button Content="Annuler" Width="96" Margin="0,0,12,0" Command="{Binding NoCommand}"/>
                <Button Content="Supprimer" Width="96" Background="{DynamicResource AccentColor}" Foreground="White" Command="{Binding YesCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>