<UserControl x:Class="Dental_App.Views.RadioImagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource PrimaryBackground}">

    <UserControl.Resources>
        <!-- Patient Item Style -->
        <Style x:Key="PatientButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Image Card Style -->
        <Style x:Key="ImageCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource CardBackground}"
                                CornerRadius="12"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource BorderColor}"
                                ClipToBounds="True">
                            <StackPanel>
                                <Border Height="200" Background="{DynamicResource SecondaryBackground}" CornerRadius="12,12,0,0" Margin="0">
                                    <Image Source="{Binding ImagePath}" 
                                           Stretch="UniformToFill"
                                           StretchDirection="Both"/>
                                </Border>
                                <StackPanel Margin="16">
                                    <TextBlock Text="{Binding ImageType}" 
                                               Foreground="{DynamicResource TextPrimary}" 
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DateTaken, StringFormat='yyyy-MM-dd'}" 
                                               Foreground="{DynamicResource TextSecondary}" 
                                               FontSize="12" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.95"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SVG Icon Button Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar - Patient List -->
        <Border Grid.Column="0" Background="{DynamicResource PrimaryBackground}" Padding="20,30,20,30">
            <StackPanel VerticalAlignment="Top">
                <!-- Title -->
                <TextBlock Text="Radio Images" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" Margin="0,0,0,30"/>

                <!-- Search Box -->
                <Border Background="{DynamicResource SecondaryBackground}" CornerRadius="12" Margin="0,0,0,20" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
                    <Grid Margin="16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="M9.5,2A7.5,7.5 0 0,1 17,9.5A7.5,7.5 0 0,1 9.5,17A7.5,7.5 0 0,1 2,9.5A7.5,7.5 0 0,1 9.5,2M9.5,4A5.5,5.5 0 0,0 4,9.5A5.5,5.5 0 0,0 9.5,15A5.5,5.5 0 0,0 15,9.5A5.5,5.5 0 0,0 9.5,4M14.5,13L21,19.5L19.5,21L13,14.5Z"
                              Fill="{DynamicResource TextSecondary}"
                              Width="18" Height="18" Stretch="Uniform" 
                              VerticalAlignment="Center" HorizontalAlignment="Left"
                              Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextSecondary}"
                                 BorderThickness="0"
                                 FontSize="13"
                                 Padding="0"/>
                    </Grid>
                </Border>

                <!-- Patient List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                    <ItemsControl ItemsSource="{Binding Patients}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectPatientCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Height" Value="Auto"/>
                                            <Setter Property="Margin" Value="0,8"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Padding" Value="16,12"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" 
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="12">
                                                            <ContentPresenter VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding FullName}" 
                                                   Foreground="{DynamicResource TextPrimary}" 
                                                   FontSize="14" FontWeight="SemiBold"
                                                   TextAlignment="Center"/>
                                        <TextBlock Text="{Binding Phone}" 
                                                   Foreground="{DynamicResource TextSecondary}" 
                                                   FontSize="12" Margin="0,6,0,0"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Right Content Area -->
        <Grid Grid.Column="1" Background="{DynamicResource PrimaryBackground}">
            <!-- Empty State -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding HasSelectedPatient, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=True}">
                <Path Data="M19,13H5V8H19M19,3H5C3.9,3 3,3.9 3,5V19C3,20.1 3.9,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.9 20.1,3 19,3M15.5,6C16.33,6 17,6.67 17,7.5C17,8.33 16.33,9 15.5,9C14.67,9 14,8.33 14,7.5C14,6.67 14.67,6 15.5,6Z"
                      Fill="{DynamicResource TextSecondary}" 
                      Width="80" Height="80" Stretch="Uniform"
                      Opacity="0.3"
                      Margin="0,0,0,20"/>
                <TextBlock Text="Selectionnez un patient" 
                           Foreground="{DynamicResource TextPrimary}" 
                           FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Content with Patient Data -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasSelectedPatient, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Margin="40">
                    <!-- Header -->
                    <Grid Margin="0,0,0,30">
                        <StackPanel VerticalAlignment="Top">
                            <TextBlock Text="{Binding SelectedPatient.FullName, StringFormat='Radios — {0}'}" 
                                       Foreground="{DynamicResource TextPrimary}" 
                                       FontSize="22" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Foreground="{DynamicResource TextSecondary}" 
                                       FontSize="13"
                                       Text="{Binding RadioImages.Count, StringFormat='{}{0} radio(s) enregistrée(s)'}"/>
                        </StackPanel>

                        <!-- Add Button -->
                        <Button HorizontalAlignment="Right" 
                                VerticalAlignment="Top"
                                Content="+ Ajouter Radio"
                                Foreground="White"
                                Background="{DynamicResource AccentColor}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Command="{Binding AddRadioCommand}"
                                Margin="16,0,0,0"
                                Padding="20,12"
                                BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="24"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Images Grid -->
                    <ItemsControl ItemsSource="{Binding RadioImages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource ImageCardButtonStyle}"
                                        Command="{Binding DataContext.ViewImageCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- No Images Message -->
                    <TextBlock Text="Aucune radio enregistrée pour ce patient"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,40,0,0">
                        <TextBlock.Visibility>
                            <MultiBinding Converter="{StaticResource BooleanToVisibilityConverter}">
                                <Binding Path="RadioImages.Count"/>
                            </MultiBinding>
                        </TextBlock.Visibility>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>

</UserControl>
