<UserControl x:Class="Dental_App.Views.ColorPickerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBackground}"
             Width="350"
             Height="400"
             Padding="20">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Select Drawing Color" 
                   FontSize="16" 
                   FontWeight="Bold" 
                   Margin="0,0,0,15"
                   Foreground="{DynamicResource TextPrimary}"/>

        <!-- Hue Spectrum Gradient -->
        <Rectangle Grid.Row="1" 
                   x:Name="HueGradient"
                   Height="30" 
                   Margin="0,0,0,10"
                   Cursor="Hand"
                   MouseDown="HueGradient_MouseDown"
                   MouseMove="HueGradient_MouseMove"/>

        <!-- Saturation & Value Picker -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <!-- Color Square -->
            <Grid x:Name="ColorSquare" 
                  Cursor="Hand"
                  MouseDown="ColorSquare_MouseDown"
                  MouseMove="ColorSquare_MouseMove"
                  Height="150"
                  Background="Transparent">
                
                <Rectangle x:Name="ColorSquareHue" Fill="Red" />
                
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="Black" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>
        </Grid>

        <!-- Color Preview -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Selected Color:" 
                       VerticalAlignment="Center" 
                       Margin="0,0,10,0"
                       Foreground="{DynamicResource TextSecondary}"/>
            <Rectangle x:Name="PreviewRect" 
                       Width="80" 
                       Height="30" 
                       Fill="Red" 
                       Stroke="{DynamicResource BorderColor}"
                       StrokeThickness="1"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="ColorHexText" 
                       Text="#FF0000" 
                       VerticalAlignment="Center" 
                       Margin="15,0,0,0"
                       FontFamily="Courier New"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="12"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" 
                    Click="OK_Click" 
                    Width="80" 
                    Padding="10,8"
                    Margin="0,0,10,0"
                    Background="{DynamicResource AccentColor}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Cancel" 
                    Click="Cancel_Click" 
                    Width="80" 
                    Padding="10,8"
                    Background="Transparent"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    Foreground="{DynamicResource TextPrimary}"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
