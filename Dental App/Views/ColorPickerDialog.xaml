<UserControl x:Class="Dental_App.Views.ColorPickerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White"
             Width="350"
             Height="400"
             Padding="20">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Select Drawing Color" 
                   FontSize="16" 
                   FontWeight="Bold" 
                   Margin="0,0,0,15"
                   Foreground="#333"/>

        <!-- Hue Spectrum Gradient -->
        <Rectangle Grid.Row="1" 
                   x:Name="HueGradient"
                   Height="30" 
                   Margin="0,0,0,10"
                   Cursor="Hand"
                   MouseDown="HueGradient_MouseDown"
                   MouseMove="HueGradient_MouseMove"/>

        <!-- Saturation & Value Picker -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>

            <!-- Color Square -->
            <Rectangle Grid.Column="0" 
                       x:Name="ColorSquare" 
                       Cursor="Hand"
                       MouseDown="ColorSquare_MouseDown"
                       MouseMove="ColorSquare_MouseMove"
                       Height="150"/>

            <!-- Value Slider (brightness) -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Stretch">
                <Slider x:Name="ValueSlider" 
                        Orientation="Vertical" 
                        Minimum="0" 
                        Maximum="100" 
                        Value="100"
                        VerticalAlignment="Stretch"
                        ValueChanged="ValueSlider_ValueChanged"/>
            </StackPanel>
        </Grid>

        <!-- Color Preview -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Selected Color:" 
                       VerticalAlignment="Center" 
                       Margin="0,0,10,0"
                       Foreground="#333"/>
            <Rectangle x:Name="PreviewRect" 
                       Width="80" 
                       Height="30" 
                       Fill="Red" 
                       Stroke="#CCC"
                       StrokeThickness="1"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="ColorHexText" 
                       Text="#FF0000" 
                       VerticalAlignment="Center" 
                       Margin="15,0,0,0"
                       FontFamily="Courier New"
                       Foreground="#666"
                       FontSize="12"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" 
                    Click="OK_Click" 
                    Width="80" 
                    Padding="10,8"
                    Margin="0,0,10,0"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Cursor="Hand"/>
            <Button Content="Cancel" 
                    Click="Cancel_Click" 
                    Width="80" 
                    Padding="10,8"
                    Background="#F44336"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>
