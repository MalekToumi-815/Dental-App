<UserControl x:Class="Dental_App.Views.RendezVousView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource PrimaryBackground}">
    
    <UserControl.Resources>
        <Style x:Key="TimeSlotStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalElementBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBackground}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBackground}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalElementBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- DatePickerTextBox style for consistent date input appearance -->
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                        <ScrollViewer x:Name="PART_ContentHost" 
                                      Focusable="False" 
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FormDatePickerStyle copied from ConsultationDialogView for unified styling -->
        <Style x:Key="FormDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="IsTodayHighlighted" Value="True"/>
            <Setter Property="SelectedDateFormat" Value="Short"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid x:Name="DatePickerRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Focusable="{TemplateBinding Focusable}"
                                               HorizontalContentAlignment="Stretch"
                                               VerticalContentAlignment="Center"
                                               Background="Transparent"
                                               Foreground="{TemplateBinding Foreground}"
                                               BorderThickness="0"
                                               Padding="12,2"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               CaretBrush="{DynamicResource AccentColor}"/>

                            <Button Grid.Column="1"
                                    x:Name="PART_Button"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="8"
                                    Foreground="{DynamicResource TextPrimary}"
                                    Cursor="Hand"
                                    Focusable="False">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="M 4 2 L 4 4 L 3 4 L 3 21 L 21 21 L 21 4 L 20 4 L 20 2 L 18 2 L 18 4 L 6 4 L 6 2 L 4 2 M 5 8 L 5 20 L 20 20 L 20 8 L 5 8 M 7 10 L 9 10 L 9 12 L 7 12 L 7 10 M 12 10 L 14 10 L 14 12 L 12 12 L 12 10 M 17 10 L 19 10 L 19 12 L 17 12 L 17 10 M 7 14 L 9 14 L 9 16 L 7 16 L 7 14 M 12 14 L 14 14 L 14 16 L 12 16 L 12 14 M 17 14 L 19 14 L 19 16 L 17 16 L 17 14 M 7 18 L 9 18 L 9 20 L 7 20 L 7 18 M 12 18 L 14 18 L 14 20 L 12 20 L 12 18 M 17 18 L 19 18 L 19 20 L 17 20 L 17 18 Z"
                                          Fill="{DynamicResource TextPrimary}"/>
                                </Viewbox>
                            </Button>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   IsOpen="{Binding IsOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource GlobalElementBorderBrush}"
                                        BorderThickness="2"
                                        CornerRadius="6"
                                        Margin="0,5,0,0">
                                    <Calendar x:Name="PART_Calendar"
                                              SelectedDate="{Binding SelectedDate, RelativeSource={RelativeSource TemplatedParent}}"
                                              DisplayDate="{Binding DisplayDate, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="{DynamicResource CardBackground}"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalElementBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter x:Name="ContentPresenter"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      Margin="0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"/>

                                    <ToggleButton x:Name="PART_ToggleButton"
                                                  Grid.Column="1"
                                                  ClickMode="Press"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Foreground="{DynamicResource TextPrimary}"
                                                  Padding="5">
                                        <Path Data="M 0 0 L 4 4 L 8 0 Z" 
                                              Fill="{DynamicResource TextPrimary}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide"
                                   Margin="0,2,0,0">
                                <Border Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource GlobalElementBorderBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        Padding="0"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SecondaryBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PrimaryBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="20">
            <TextBlock Text="Rendez-Vous" Foreground="{DynamicResource TextPrimary}" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <Border Background="{DynamicResource CardBackground}" 
                    CornerRadius="15" 
                    Padding="20,20,20,20" 
                    Margin="0,0,0,20" 
                    BorderBrush="{DynamicResource GlobalElementBorderBrush}" 
                    BorderThickness="2"
                    ClipToBounds="True">
                <Grid>
                    <Calendar x:Name="MainCalendar"
                              Background="{DynamicResource CardBackground}" 
                              Foreground="{DynamicResource TextPrimary}"
                              BorderThickness="2"
                              BorderBrush="White"
                              SelectedDate="{Binding SelectedDate}"
                              Padding="0"
                              Style="{StaticResource ChicCalendarStyle}"
                              DisplayDateChanged="Calendar_DisplayDateChanged">
                        <Calendar.Resources>
                            <Style TargetType="CalendarDayButton" BasedOn="{StaticResource ChicCalendarDayButtonStyle}"/>
                        </Calendar.Resources>
                    </Calendar>
                    <!-- Overlay grid to hide the white border -->
                    <Grid IsHitTestVisible="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="2"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2"/>
                        </Grid.ColumnDefinitions>
                        <!-- Top border cover -->
                        <Rectangle Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Fill="{DynamicResource CardBackground}"/>
                        <!-- Bottom border cover -->
                        <Rectangle Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Fill="{DynamicResource CardBackground}"/>
                        <!-- Left border cover -->
                        <Rectangle Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Fill="{DynamicResource CardBackground}"/>
                        <!-- Right border cover -->
                        <Rectangle Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" Fill="{DynamicResource CardBackground}"/>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel>
                <TextBlock Text="Statistiques" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <Border Background="{DynamicResource CardBackground}" CornerRadius="10" Padding="15" Margin="0,5" BorderBrush="{DynamicResource GlobalElementBorderBrush}" BorderThickness="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Aujourd'hui" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding TodayCount}" Foreground="{DynamicResource AccentColor}" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Cette Semaine" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding WeekCount}" Foreground="{DynamicResource AccentColor}" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="20">
            <Grid Margin="0,0,0,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Rendez-Vous du Jour" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="DateLabel" Text="{Binding DateLabel}" Foreground="{DynamicResource TextSecondary}" FontSize="14"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" 
                        Style="{StaticResource ButtonStyle}"
                        Padding="20,0" Height="42"
                        Command="{Binding OpenModalCommand}"
                        x:Name="NewRdvButton">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="+"
                                   FontSize="20" FontWeight="Bold"
                                   Margin="0,0,8,2"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Nouveau RDV"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <ListBox Background="Transparent" BorderThickness="0" 
                     ItemsSource="{Binding RendezVousList}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Border Background="{DynamicResource CardBackground}" 
                                    CornerRadius="12" 
                                    Padding="0" 
                                    Margin="0,8" 
                                    MouseLeftButtonUp="OnRendezVousClicked"
                                    Cursor="Hand" 
                                    BorderBrush="{DynamicResource GlobalElementBorderBrush}" 
                                    BorderThickness="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status Color Bar Left -->
                                    <Border Grid.Column="0" 
                                            Width="6" 
                                            CornerRadius="12,0,0,12"
                                            Background="{Binding Statut, Converter={StaticResource StatutToColorConverter}}"/>

                                    <!-- Initials Badge -->
                                    <Border Grid.Column="1" 
                                            Width="50" 
                                            Height="50" 
                                            CornerRadius="8" 
                                            Background="{DynamicResource SecondaryBackground}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Margin="12,12,12,12"
                                            BorderBrush="{DynamicResource GlobalElementBorderBrush}"
                                            BorderThickness="2">
                                        <TextBlock Text="{Binding InitialesPatient}" 
                                                  Foreground="{DynamicResource AccentColor}" 
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center" 
                                                  FontSize="13" 
                                                  FontWeight="Bold"/>
                                    </Border>

                                    <!-- Patient Info and Time -->
                                    <StackPanel Grid.Column="2" 
                                               Margin="0,12,12,12" 
                                               VerticalAlignment="Center">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding NomPatient}" 
                                                      Foreground="{DynamicResource TextPrimary}" 
                                                      FontWeight="SemiBold"
                                                      FontSize="14"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                      Text="{Binding Heure}" 
                                                      Foreground="{DynamicResource TextSecondary}" 
                                                      FontSize="12"
                                                      FontWeight="SemiBold"
                                                      VerticalAlignment="Center"
                                                      Margin="10,0,0,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <StackPanel Grid.Column="3"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,15,0">
                                        <Border Background="{Binding Statut, Converter={StaticResource StatutToColorConverter}}"
                                                CornerRadius="6"
                                                Padding="8,4">
                                            <TextBlock Text="{Binding Statut}" 
                                                      Foreground="{DynamicResource PrimaryBackground}" 
                                                      FontSize="11" 
                                                      FontWeight="Bold"
                                                      TextAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <Grid x:Name="ModalOverlay" Grid.ColumnSpan="2" Background="#AA000000" 
              Visibility="{Binding IsModalVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="500" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Background="{DynamicResource CardBackground}" CornerRadius="15" Padding="25" BorderBrush="{DynamicResource GlobalElementBorderBrush}" BorderThickness="2">
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="{Binding ModalTitle}" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold"/>
                        <Button Content="X" HorizontalAlignment="Right" Background="Transparent" 
                               Foreground="{DynamicResource TextSecondary}" BorderThickness="0" FontSize="16"
                               Command="{Binding CloseModalCommand}"
                               x:Name="CloseModalButton"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,15,0,5">
                        <TextBlock Text="PATIENT" Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text=" *" Foreground="#EF4444" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBox Height="40" Style="{StaticResource TextBoxStyle}"
                             Text="{Binding PatientSearchViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             x:Name="PatientSearchBox"/>
                    
                    <ItemsControl ItemsSource="{Binding PatientSearchViewModel.SuggestedPatients}"
                                  Visibility="{Binding PatientSearchViewModel.IsSuggestionsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Margin="0,5,0,10"
                                  MaxHeight="150">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" BorderThickness="0,2,0,0" BorderBrush="{DynamicResource GlobalElementBorderBrush}"
                                        Background="{DynamicResource CardBackground}" 
                                        MouseLeftButtonUp="OnPatientSuggestionClicked"
                                        Cursor="Hand">
                                    <TextBlock Foreground="{DynamicResource TextPrimary}" FontSize="12">
                                        <Run Text="{Binding Nom, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Prenom, Mode=OneWay}"/>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="{DynamicResource SecondaryBackground}" BorderBrush="{DynamicResource GlobalElementBorderBrush}" BorderThickness="2" Padding="10,8" 
                            Visibility="{Binding SelectedPatient, Converter={StaticResource NullToVisibilityConverter}}"
                            Margin="0,0,0,15">
                        <TextBlock Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="11">
                            <Run Text="Patient: "/>
                            <Run Text="{Binding SelectedPatient.Nom, Mode=OneWay}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding SelectedPatient.Prenom, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,15,0,5">
                        <TextBlock Text="DATE" Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text=" *" Foreground="#EF4444" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Border Background="{DynamicResource SecondaryBackground}" 
                            BorderBrush="{DynamicResource GlobalElementBorderBrush}" 
                            BorderThickness="2" 
                            CornerRadius="8">
                        <DatePicker SelectedDate="{Binding NewRendezVousDate}"
                                    Style="{StaticResource FormDatePickerStyle}"/>
                    </Border>
                        
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,10">
                        <TextBlock Text="CRENEAU HORAIRE" Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text=" *" Foreground="#EF4444" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ToggleButton Grid.Row="0" Grid.Column="0" Content="08:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="08:30" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="0" Grid.Column="1" Content="09:00" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="09:00" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="0" Grid.Column="2" Content="09:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="09:30" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="0" Grid.Column="3" Content="10:00" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="10:00" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="1" Grid.Column="0" Content="10:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="10:30" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="1" Grid.Column="1" Content="11:00" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="11:00" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="1" Grid.Column="2" Content="11:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="11:30" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="1" Grid.Column="3" Content="12:00" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="12:00" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="2" Grid.Column="0" Content="12:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="12:30" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="2" Grid.Column="1" Content="13:00" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="13:00" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="2" Grid.Column="2" Content="13:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="13:30" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="2" Grid.Column="3" Content="14:00" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="14:00" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="3" Grid.Column="0" Content="14:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="14:30" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="3" Grid.Column="1" Content="15:00" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="15:00" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="3" Grid.Column="2" Content="15:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="15:30" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="3" Grid.Column="3" Content="16:00" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="16:00" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="4" Grid.Column="0" Content="16:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="16:30" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="4" Grid.Column="1" Content="17:00" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="17:00" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="4" Grid.Column="2" Content="17:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="17:30" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="4" Grid.Column="3" Content="18:00" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="18:00" Click="OnTimeSlotClicked"/>
                        <ToggleButton Grid.Row="5" Grid.Column="0" Content="18:30" Margin="2" Style="{StaticResource TimeSlotStyle}" Tag="18:30" Click="OnTimeSlotClicked"/>
                    </Grid>

                    <TextBlock Text="STATUT" Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="Bold" Margin="0,15,0,5"
                               Visibility="{Binding IsEditingExistingAppointment, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <ComboBox Height="40" 
                              Background="{DynamicResource SecondaryBackground}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource GlobalElementBorderBrush}"
                              BorderThickness="2"
                              Padding="10,8"
                              ItemsSource="{Binding StatusList}"
                              SelectedItem="{Binding SelectedStatus}"
                              Style="{StaticResource ComboBoxStyle}"
                              ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                              Visibility="{Binding IsEditingExistingAppointment, Converter={StaticResource BooleanToVisibilityConverter}}"
                              x:Name="StatusComboBox"/>

                    

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Annuler" Background="{DynamicResource BorderColor}" Foreground="{DynamicResource TextPrimary}" 
                                FontWeight="Bold" Height="45" Margin="0,0,5,0" BorderThickness="0"
                                Command="{Binding CloseModalCommand}"
                                x:Name="CancelButton">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="15,10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="1" Content="Confirmer RDV" Style="{StaticResource ButtonStyle}" 
                               Height="45" Margin="5,0,0,0"
                               Command="{Binding SaveRendezVousCommand}"
                               x:Name="ConfirmButton"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
