<UserControl x:Class="Dental_App.Views.ProthesisteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:local="clr-namespace:Dental_App.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             Background="{DynamicResource PrimaryBackground}">

	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>
		<local:InverseBooleanConverter x:Key="InverseBoolToVis"/>

		<!-- Style TextBox avec placeholder amélioré -->
		<Style x:Key="InputStyle" TargetType="TextBox">
			<Setter Property="Background"      Value="{DynamicResource SecondaryBackground}"/>
			<Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
			<Setter Property="BorderBrush"     Value="{DynamicResource BorderColor}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="FontSize"        Value="14"/>
			<Setter Property="Height"          Value="44"/>
			<Setter Property="CaretBrush"      Value="{DynamicResource AccentColor}"/>
			<Setter Property="Padding"         Value="12,0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
							<Grid Margin="12,0">
								<TextBlock x:Name="Placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
								<ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"/>
							</Grid>
						</Border>
						<ControlTemplate.Triggers>
							<MultiTrigger>
								<MultiTrigger.Conditions>
									<Condition Property="Text" Value=""/>
									<Condition Property="IsKeyboardFocused" Value="False"/>
								</MultiTrigger.Conditions>
								<Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
							</MultiTrigger>
							<Trigger Property="IsKeyboardFocused" Value="True">
								<Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed"/>
							</Trigger>
							<Trigger Property="Text" Value="">
								<Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Bouton Teal -->
		<Style x:Key="TealBtn" TargetType="Button">
			<Setter Property="Background"      Value="{DynamicResource AccentColor}"/>
			<Setter Property="Foreground"      Value="{DynamicResource PrimaryBackground}"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="FontSize"        Value="14"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Bouton icône -->
		<Style x:Key="IconBtn" TargetType="Button">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Width"           Value="32"/>
			<Setter Property="Height"          Value="32"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackground}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>

	<Grid>
		<!-- CONTENU PRINCIPAL -->
		<Grid Margin="32,28">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="24"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="16"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- En-tête -->
			<Grid Grid.Row="0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBlock Text="Prothésistes"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="28" FontWeight="Bold"
                           VerticalAlignment="Center"/>

				<Button Grid.Column="1"
                        Style="{StaticResource TealBtn}"
                        Padding="20,0" Height="42"
                        Command="{Binding OpenModalCommand}">
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
						<TextBlock Text="+"
                                   FontSize="20" FontWeight="Bold"
                                   Margin="0,0,8,2"
                                   VerticalAlignment="Center"/>
						<TextBlock Text="Nouveau Prothésiste"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
					</StackPanel>
				</Button>
			</Grid>

			<!-- Barre de recherche -->
			<StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
				<TextBox Style="{StaticResource InputStyle}"
                         Tag="Rechercher par Nom ou Téléphone "
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Width="250"/>

				<Button Style="{StaticResource TealBtn}"
                        Command="{Binding ClearSearchCommand}"
                        Width="44" Height="44"
                        Margin="8,0,0,0"
                        ToolTip="Effacer la recherche">
					<TextBlock Text="✕"
                               Foreground="{DynamicResource PrimaryBackground}"
                               FontSize="18"
                               FontWeight="Bold"/>
				</Button>
			</StackPanel>

			<!-- Tableau -->
			<Border Grid.Row="4"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    ClipToBounds="True">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<!-- En-tête colonnes -->
					<Border BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            Padding="20,14"
                            Background="{DynamicResource PrimaryBackground}">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="60"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="200"/>
								<ColumnDefinition Width="150"/>
								<ColumnDefinition Width="140"/>
								<ColumnDefinition Width="100"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="#"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" FontWeight="SemiBold"/>
							<TextBlock Grid.Column="1" Text="NOM"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" FontWeight="SemiBold"/>
							<TextBlock Grid.Column="2" Text="ADRESSE"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" FontWeight="SemiBold"/>
							<TextBlock Grid.Column="3" Text="TÉLÉPHONE"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" FontWeight="SemiBold"/>
							<TextBlock Grid.Column="4" Text="NB COMMANDES"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" FontWeight="SemiBold"/>
							<TextBlock Grid.Column="5" Text="ACTIONS"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
						</Grid>
					</Border>

					<!-- Lignes -->
					<ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
						<ItemsControl x:Name="ProthesisteList"
                                      ItemsSource="{Binding Prosthesists}"
                                      HorizontalContentAlignment="Stretch">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="0,0,0,1"
                                            Padding="20,16">
										<Border.Style>
											<Style TargetType="Border">
												<Setter Property="Background" Value="Transparent"/>
												<Style.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
													</Trigger>
												</Style.Triggers>
											</Style>
										</Border.Style>
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="60"/>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="200"/>
												<ColumnDefinition Width="150"/>
												<ColumnDefinition Width="140"/>
												<ColumnDefinition Width="100"/>
											</Grid.ColumnDefinitions>

											<TextBlock Grid.Column="0"
                                                       Text="{Binding Id}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>

											<TextBlock Grid.Column="1"
                                                       Text="{Binding Nom}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>

											<TextBlock Grid.Column="2"
                                                       Text="{Binding Adresse}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>

											<TextBlock Grid.Column="3"
                                                       Text="{Binding Telephone}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>

											<TextBlock Grid.Column="4"
                                                       Text="{Binding NbCommandes}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>

											<StackPanel Grid.Column="5"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
												<!-- Modifier -->
												<Button Style="{StaticResource IconBtn}"
                                                        Margin="0,0,6,0"
                                                        ToolTip="Modifier"
                                                        Command="{Binding DataContext.EditCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
													<Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75zM20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75z"
                                                          Fill="{DynamicResource AccentColor}"
                                                          Width="15" Height="15"
                                                          Stretch="Uniform"/>
												</Button>
											</StackPanel>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</Grid>
			</Border>
		</Grid>

		<!-- MODAL OVERLAY -->
		<Grid Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVis}}">

			<!-- Fond sombre -->
			<Rectangle Fill="#000000" Opacity="0.65"/>

			<!-- Carte modale -->
			<Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Width="500"
                    Padding="30,26"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
				<StackPanel>

					<!-- Titre + bouton fermer -->
					<Grid Margin="0,0,0,22">
						<TextBlock Text="Nouveau Prothésiste"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="20" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
						<Button HorizontalAlignment="Right"
                                Style="{StaticResource IconBtn}"
                                Command="{Binding CloseModalCommand}"
                                ToolTip="Fermer">
							<TextBlock Text="✕"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Button>
					</Grid>

					<!-- Nom -->
					<StackPanel Margin="0,0,0,16">
						<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
							<TextBlock Text="Nom"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="14" FontWeight="SemiBold"/>
							<TextBlock Text=" *"
                                       Foreground="#EF4444"
                                       FontSize="14" FontWeight="SemiBold"/>
						</StackPanel>
						<TextBox Style="{StaticResource InputStyle}"
                                 Tag="Nom du laboratoire"
                                 Text="{Binding NewNom, UpdateSourceTrigger=PropertyChanged}"/>
					</StackPanel>

					<!-- Adresse -->
					<StackPanel Margin="0,0,0,16">
						<TextBlock Text="Adresse"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
						<TextBox Style="{StaticResource InputStyle}"
                                 Tag="Adresse"
                                 Text="{Binding NewAdresse, UpdateSourceTrigger=PropertyChanged}"/>
					</StackPanel>

					<!-- Téléphone -->
					<StackPanel Margin="0,0,0,24">
						<TextBlock Text="Téléphone"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
						<TextBox Style="{StaticResource InputStyle}"
                                 Tag="XX XXX XXX"
                                 Text="{Binding NewTelephone, UpdateSourceTrigger=PropertyChanged}"/>
					</StackPanel>

					<!-- Bouton Enregistrer -->
					<Button Content="Enregistrer"
                            Style="{StaticResource TealBtn}"
                            Height="46"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Command="{Binding SaveCommand}"/>
				</StackPanel>
			</Border>
		</Grid>

	</Grid>
</UserControl>