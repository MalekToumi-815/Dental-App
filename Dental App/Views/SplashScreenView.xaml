<Window x:Class="Dental_App.Views.SplashScreenView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        Background="{DynamicResource PrimaryBackground}"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Width="600" Height="360"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Image spans both rows and fills the whole window exactly -->
        <Image x:Name="BackgroundImage"
               Source="pack://siteoforigin:,,,/Assets/Images/loadscreen.jpg"
               Stretch="Fill"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               Grid.Row="0" Grid.RowSpan="2"/>

        <!-- Loading indicator row (overlays the image at the bottom) -->
        <Grid Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,12,0,16" IsHitTestVisible="False">
            <ProgressBar Width="220" Height="6" IsIndeterminate="True" Foreground="{DynamicResource AccentColor}" Background="#33FFFFFF"/>
        </Grid>
    </Grid>
</Window>